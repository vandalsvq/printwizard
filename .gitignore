.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore folders generated by Bundler
.bundle/
vendor/

# Astro / Node (новый сайт на Astro Starlight, см. plans/pw-263/)
node_modules/
dist/
.astro/
.DS_Store

# public/img, public/draw_io, public/docs — коммитятся как источник
