# Copied from https://github.com/github/gitignore/blob/main/Jekyll.gitignore
# Ignore metadata generated by Jekyll
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore folders generated by Bundler
.bundle/
vendor/

# Astro / Node (новый сайт на Astro Starlight, см. plans/pw-263/)
node_modules/
dist/
.astro/
.DS_Store

# Картинки документации — копируются скриптом миграции из docs/img
# (npm run migrate). Не дублируем 12 МБ бинарников в git.
public/img/
# Редирект-заглушки старых /docs/*.html — генерируются скриптом миграции.
public/docs/
# Схемы draw_io — копируются скриптом миграции из docs/draw_io.
public/draw_io/

# Python (инструментарий tools/docs-llm/ и docs/regmin/build_docs.py)
__pycache__/
*.py[cod]