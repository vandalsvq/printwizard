  link:
    '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  print:
    '<polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>',
  registry:
    '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
  qr:
    '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><line x1="14" y1="14" x2="14" y2="14"/><line x1="21" y1="14" x2="21" y2="21"/><line x1="14" y1="21" x2="17" y2="21"/><line x1="17" y1="17" x2="17" y2="17"/>',
  boxup:
    '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
};

const features = [
  { color: 'var(--lime)', icon: 'noconfig', title: 'Без конфигуратора', text: 'Проектируйте и дорабатывайте печатные формы в режиме 1С:Предприятие — без снятия конфигурации с поддержки.' },
  { color: 'var(--blue)', icon: 'link', title: 'Прозрачные связи', text: 'Автоматический анализ пути от запроса к данным и до значения в готовом макете печатной формы.' },
  { color: 'var(--lavender)', icon: 'print', title: 'Пакетная печать', text: 'Быстрая печать по сочетанию Alt+P с анализом открытых форм и пакетный вывод любых форм.' },
  { color: 'var(--accent)', icon: 'registry', title: 'Единый реестр', text: 'Все печатные формы конфигурации в одном хранилище с общим доступом для всех участников.' },
  { color: 'var(--lime)', icon: 'qr', title: 'QR и УФЭБС', text: 'Генератор QR-кодов, включая формат быстрого платежа (УФЭБС), а также XML и JSON.' },
  { color: 'var(--blue)', icon: 'boxup', title: 'Экспорт', text: 'Выгрузка в расширение, внешнюю печатную форму или XML с XDTO-схемой для обмена.' },
];

const personas = [
  { color: 'var(--lime)', title: 'Аналитик', text: 'Собирает печатную форму как пазл — запросы, наборы и макет без единой строки в конфигураторе.' },
  { color: 'var(--blue)', title: 'Разработчик', text: 'Консоль кода с подсказками, отладка запросов, сравнение макетов и экспорт в расширение.' },
  { color: 'var(--lavender)', title: 'Руководитель проекта', text: 'Единый реестр форм, прозрачность связей и совместная разработка без дублирования работ.' },
];

const configs = [
  '1С:Бухгалтерия',
  '1С:ERP',
  '1С:Управление производством',
  '1С:Управление торговлей',
  '1С:Зарплата и управление персоналом',
  '1С:Комплексная автоматизация',
];

const plans = [
  {
    name: 'Коммерческая версия',
    tag: 'Доступна',
    tagColor: 'var(--lime)',
    text: 'Полная функциональность. Тарифы и покупка — на Infostart Marketplace.',
    points: ['Все возможности конструктора', 'Обновления и техподдержка', 'Тарифы DEV / PROF / CORP'],
    cta: { label: 'Купить на Infostart', href: 'https://infostart.ru/marketplace/1918555/', primary: true },
  },
  {
    name: 'Community-версия',
    tag: 'Скоро',
    tagColor: 'var(--blue)',
    text: 'Бесплатная версия с базовыми возможностями. В разработке — следите за анонсом.',
    points: ['Базовые возможности', 'Бесплатно', 'Анонс — в Telegram-канале'],
    cta: { label: 'Следить в Telegram', href: 'https://t.me/isprintwizard', primary: false },
  },
];

const faq = [
  {
    q: 'Нужно ли снимать конфигурацию с поддержки?',
    a: 'Нет. PrintWizard — это расширение: оно не меняет конфигурацию, не требует снятия с поддержки и не мешает обновлениям.',
  },
  {
    q: 'С какими конфигурациями работает?',
    a: 'С большинством современных конфигураций на платформе 1С:Предприятие 8.3 — Бухгалтерия, ERP, Управление производством, Управление торговлей, ЗУП и другими.',
  },
  {
    q: 'Нужны ли навыки программирования?',
    a: 'Нет. Достаточно базовых знаний: конструктор и консоль запросов, наборы данных и редактор макета работают в пользовательском режиме 1С:Предприятие.',
  },
  {
    q: 'Поддерживаются ли документы Word (.docx)?',
    a: 'Да. Печатные формы создаются в формате табличного и офисного (.docx) документа; содержимое DOCX можно просматривать прямо в окне макета.',
  },
  {
    q: 'Можно ли добавить QR-код?',
    a: 'Да. Встроенный генератор QR-кодов поддерживает формат быстрого платежа (УФЭБС), а также XML и JSON.',
  },
  {
    q: 'Какие версии есть?',
    a: 'Коммерческая версия доступна на Infostart Marketplace. Бесплатная community-версия — в разработке.',
  },
];

const docsUrl = '/guide/';
const githubUrl = 'https://github.com/vandalsvq/printwizard';
const tgUrl = 'https://t.me/isprintwizard';
const marketplaceUrl = 'https://infostart.ru/marketplace/1918555/';
const issuesUrl = 'https://github.com/vandalsvq/printwizard/issues';

// Структурированные данные (schema.org) для поисковиков — Organization (правообладатель),
// SoftwareApplication (продукт) и FAQPage (тот же список вопросов, что виден на странице).
const siteUrl = 'https://printwizard.ru';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'ООО «Энспейс»',
      url: siteUrl,
      logo: `${siteUrl}/favicon.png`,
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${siteUrl}/#software`,
      name: 'PrintWizard',
      description:
        'Расширение для 1С:Предприятие: разработка печатных форм без конфигуратора, единый реестр, пакетная печать, QR-коды, экспорт в расширение.',
      applicationCategory: 'BusinessApplication',
      operatingSystem: '1С:Предприятие 8.3',
      url: siteUrl,
      image: `${siteUrl}/og.png`,
      inLanguage: 'ru',
      author: { '@id': `${siteUrl}/#organization` },
      publisher: { '@id': `${siteUrl}/#organization` },
      offers: {
        '@type': 'Offer',
        category: 'Commercial',
        url: marketplaceUrl,
        availability: 'https://schema.org/InStock',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}/#faq`,
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="k6A_i_738r8Wxd2Q_3Z77U_J2aGatTmf7qUiZT52ttA" />
    <title>PrintWizard — конструктор печатных форм для 1С</title>
    <meta
      name="description"
      content="PrintWizard — расширение для 1С:Предприятие: разработка печатных форм без конфигуратора, единый реестр, пакетная печать, QR-коды, экспорт в расширение."
    />
    <link rel="canonical" href="https://printwizard.ru/" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://printwizard.ru/" />
    <meta property="og:title" content="PrintWizard — конструктор печатных форм для 1С" />
    <meta
      property="og:description"
      content="Создавайте печатные формы для 1С без программирования: единый реестр, пакетная печать, QR-коды, экспорт в расширение."
    />
    <meta property="og:image" content="https://printwizard.ru/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="PrintWizard — конструктор печатных форм для 1С" />
    <meta
      name="twitter:description"
      content="Создавайте печатные формы для 1С без программирования: единый реестр, пакетная печать, QR-коды, экспорт в расширение."
    />
    <meta name="twitter:image" content="https://printwizard.ru/og.png" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <div class="container inner">
        <a class="brand" href="/">
          <Image src={logo} alt="PrintWizard" width={30} height={25} />
          <span>PrintWizard</span>
        </a>
        <nav class="nav">
          <a href="#features">Возможности</a>
          <a href="#how">Как работает</a>
          <a href="#licensing">Версии</a>
          <a href="#faq">FAQ</a>
          <a href={docsUrl}>Документация</a>
          <a href={githubUrl} target="_blank" rel="noopener">GitHub</a>
        </nav>
        <a class="btn btn-primary" href={docsUrl} style="padding:9px 18px">Документация</a>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="container inner">
          <div>
            <span class="eyebrow">Расширение для 1С:Предприятие 8.3+</span>
            <h1>Конструктор печатных форм для 1С</h1>
            <p class="lead">
              Создавайте полноценные печатные формы <strong>без программирования</strong> —
              во встроенном конструкторе, прямо в режиме 1С:Предприятие.
            </p>
            <div class="puzzle-row" aria-hidden="true">
              <span style="background:var(--lime)"></span>
              <span style="background:var(--blue)"></span>
              <span style="background:var(--lavender)"></span>
              <span style="background:var(--pw-gray)"></span>
            </div>
            <div class="cta">
              <a class="btn btn-primary" href={docsUrl}>Открыть документацию</a>
              <a class="btn btn-ghost" href={marketplaceUrl} target="_blank" rel="noopener">Купить на Infostart</a>
            </div>
          </div>
          <div class="hero-figure">
            <Image src={heroShot} alt="Редактор макета печатной формы в PrintWizard (Счёт на оплату)" widths={[480, 800, 1200]} sizes="(max-width: 900px) 100vw, 620px" />
          </div>
        </div>
      </section>

      <!-- Compatibility -->
      <section class="compat-block">
        <div class="container">
          <p class="compat-lead">Работает с большинством конфигураций на 1С:Предприятие 8.3</p>
          <div class="compat">
            {configs.map((c) => <span class="compat-chip">{c}</span>)}
            <span class="compat-chip muted">и другие</span>
          </div>
          <p class="compat-note">
            Платформа 8.3.14 и выше · режим совместимости · расширение не меняет
            конфигурацию и не требует снятия с поддержки
          </p>
        </div>
      </section>

      <!-- Features -->
      <section class="block" id="features">
        <div class="container">
          <div class="section-head">
            <h2>Всё для печатных форм — в одном инструменте</h2>
            <p>От запроса к данным до готового макета. Конструктор берёт на себя рутину и делает связи прозрачными.</p>
          </div>
          <div class="features">
            {features.map((f, i) => (
              <article class="feature">
                <svg class="chip" viewBox="0 0 56 56" aria-hidden="true">
                  <path d={SHAPES[i % SHAPES.length]} fill={f.color} />
                  <g transform="translate(19,19) scale(0.75)" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[f.icon]} />
                </svg>
                <h3>{f.title}</h3>
                <p>{f.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- How it works -->
      <section class="block soft" id="how">
        <div class="container">
          <div class="section-head">
            <h2>Как это работает</h2>
            <p>Три шага от данных до печати — в привычном интерфейсе 1С:Предприятие.</p>
