      <!-- CTA band -->
      <section class="cta-band">
        <div class="container inner">
          <h2>Готовы попробовать PrintWizard?</h2>
          <p>Откройте документацию, чтобы начать, или сообщите об идее и ошибке — мы развиваем продукт вместе с сообществом.</p>
          <div class="cta" style="justify-content:center; display:flex; gap:14px; flex-wrap:wrap;">
            <a class="btn btn-primary" href={docsUrl}>Читать документацию</a>
