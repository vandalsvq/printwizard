import layoutShot from '../assets/screenshots/editor-layout.png';
import queryShot from '../assets/screenshots/query-console.png';
import printResult from '../assets/screenshots/print-result.png';

// Контур кусочка пазла со скруглёнными углами и плавными язычками (ViewBox 56×56).
// Тип каждой стороны: 1 — язычок наружу, -1 — выемка внутрь, 0 — ровный край.
function puzzlePath(top, right, bottom, left) {
  const X0 = 12, X1 = 44, Y0 = 12, Y1 = 44, c = 28, rad = 6, tw = 6, d = 6;
  const p = [`M ${X0 + rad} ${Y0}`];
  p.push(`L ${c - tw} ${Y0}`);
  if (top) p.push(`C ${c - tw} ${Y0 - top * d} ${c + tw} ${Y0 - top * d} ${c + tw} ${Y0}`);
  p.push(`L ${X1 - rad} ${Y0}`, `Q ${X1} ${Y0} ${X1} ${Y0 + rad}`);
  p.push(`L ${X1} ${c - tw}`);
  if (right) p.push(`C ${X1 + right * d} ${c - tw} ${X1 + right * d} ${c + tw} ${X1} ${c + tw}`);
  p.push(`L ${X1} ${Y1 - rad}`, `Q ${X1} ${Y1} ${X1 - rad} ${Y1}`);
  p.push(`L ${c + tw} ${Y1}`);
  if (bottom) p.push(`C ${c + tw} ${Y1 + bottom * d} ${c - tw} ${Y1 + bottom * d} ${c - tw} ${Y1}`);
  p.push(`L ${X0 + rad} ${Y1}`, `Q ${X0} ${Y1} ${X0} ${Y1 - rad}`);
  p.push(`L ${X0} ${c + tw}`);
  if (left) p.push(`C ${X0 - left * d} ${c + tw} ${X0 - left * d} ${c - tw} ${X0} ${c - tw}`);
  p.push(`L ${X0} ${Y0 + rad}`, `Q ${X0} ${Y0} ${X0 + rad} ${Y0}`, 'Z');
  return p.join(' ');
}

// 6 разных по строению кусочков (язычки/выемки на разных сторонах).
const SHAPES = [
  puzzlePath(1, -1, 0, 0),
  puzzlePath(-1, 1, 1, 0),
  puzzlePath(0, -1, 1, 1),
  puzzlePath(1, 1, -1, -1),
  puzzlePath(-1, 0, 1, 1),
  puzzlePath(1, -1, -1, 1),
];

// Внутренний SVG-контент иконок (обводка/заливка задаются на <g> в чипе).
